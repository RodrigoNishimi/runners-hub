# Postgres (mesmo banco do ETL; o app so escreve no schema "app").
# A busca tambem roda aqui — requer as extensoes pg_trgm/unaccent e o indice
# criados por ETL_pipeline_running_events/sql/008_search.sql.
DATABASE_URL=postgresql://corridas:corridas@localhost:5432/corridas

# Auth.js — gere com: npx auth secret
AUTH_SECRET=

# Resend (magic link + notificacoes). https://resend.com
AUTH_RESEND_KEY=
EMAIL_FROM=RunnersHub <onboarding@resend.dev>

# URL publica do site (usada em links de e-mail e no .ics)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
