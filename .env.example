# Postgres (mesmo banco do ETL; o app so escreve no schema "app").
# A busca tambem roda aqui — requer as extensoes pg_trgm/unaccent e o indice
# criados por ETL_pipeline_running_events/sql/008_search.sql.
DATABASE_URL=postgresql://corridas:corridas@localhost:5432/corridas

# Auth.js — gere com: npx auth secret
AUTH_SECRET=

# Login com Google (OAuth). Crie um "OAuth client ID" (tipo Web application)
# em https://console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI autorizado: {NEXT_PUBLIC_SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — usado pelo notifier (notifier/dispatch.py) para os avisos de
# preco/inscricao por e-mail. O login NAO usa mais e-mail (so Google OAuth).
# https://resend.com
RESEND_API_KEY=
EMAIL_FROM=RunnersHub <onboarding@resend.dev>

# URL publica do site (usada em links de e-mail e no .ics)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
